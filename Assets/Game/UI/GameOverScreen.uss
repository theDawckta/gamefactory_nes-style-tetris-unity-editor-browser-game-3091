.game-over-label {
    font-size: 48px;
    color: white;
    -unity-text-align: upper-center;
    margin-bottom: 20px;
    width: 100%;
}

.final-score-label {
    font-size: 32px;
    color: white;
    -unity-text-align: upper-center;
}

.region {
    width: 100%;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
}

.final-score-region {
    min-height: 50px;
}

.initials-region {
    min-height: 80px;
}

.return-prompt-region {
    min-height: 50px;
}
