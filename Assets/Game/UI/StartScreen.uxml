<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements">
    <ui:VisualElement name="startScreenRoot" style="flex-grow: 1; background-color: rgb(0, 0, 0); flex-direction: column; align-items: center; justify-content: flex-start; padding-top: 60px; padding-bottom: 40px; padding-left: 60px; padding-right: 60px;">
        <ui:Label name="titleLabel" text="TETRIS" style="font-size: 72px; -unity-font-style: bold; color: rgb(255, 255, 0); -unity-text-align: upper-center; width: 80%; margin-bottom: 40px;" />
        <ui:VisualElement name="leaderboardRegion" style="width: 80%; flex-grow: 1; flex-shrink: 1; background-color: rgb(20, 20, 20); border-color: rgb(200, 150, 0); border-width: 2px; border-radius: 4px; padding: 16px; margin-bottom: 24px; align-items: center; justify-content: center;">
            <ui:Label name="loadingLabel" text="Loading..." style="color: rgb(200, 200, 200); font-size: 24px; -unity-text-align: upper-center; width: 100%;" />
        </ui:VisualElement>
        <ui:VisualElement name="promptRegion" style="width: 80%; min-height: 60px; background-color: rgb(20, 20, 20); border-color: rgb(100, 100, 100); border-width: 1px; border-radius: 4px; padding: 12px; align-items: center; justify-content: center;" />
    </ui:VisualElement>
</ui:UXML>
